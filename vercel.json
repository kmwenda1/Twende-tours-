{
  "version": 2,
  "public": true,
  "buildCommand": "npm install && cd backend && npm install",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*\\.(html|css|js|json))$",
      "dest": "/$1"
    },
    {
      "src": "/(?!api/|.*\\.)",
      "dest": "/index.html"
    }
  ]
}