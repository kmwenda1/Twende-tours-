{
  "version": 2,
  "buildCommand": "echo 'static files ready'",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://twende-tours-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*\\.html?)/?$",
      "dest": "/$1"
    },
    {
      "src": "/(.+)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}