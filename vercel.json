{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://twende-tours-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.css)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.js)$",
      "dest": "/$1"
    },
    {
      "src": "/(?!api/|.*\\.)",
      "dest": "/index.html"
    }
  ]
}